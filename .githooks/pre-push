#!/usr/bin/env bash
# Block direct pushes to protected default branches.
# Force a PR workflow for every contributor (including repo admins on this machine).
#
# Install once per clone:
#   ./scripts/install-dev-hooks.sh
#
# Emergency override (use rarely; still blocked on GitHub if branch protection enforces admins):
#   ALLOW_DIRECT_PUSH=1 git push

set -euo pipefail

PROTECTED_BRANCHES="${PROTECTED_BRANCHES:-main master}"

if [[ "${ALLOW_DIRECT_PUSH:-}" == "1" ]]; then
  echo "pre-push: ALLOW_DIRECT_PUSH=1 set — skipping protected-branch check." >&2
  exit 0
fi

is_protected() {
  local branch="$1"
  for p in $PROTECTED_BRANCHES; do
    if [[ "$branch" == "$p" ]]; then
      return 0
    fi
  done
  return 1
}

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Deleting a remote ref is represented as zero local sha — still block main deletes.
  branch="${remote_ref#refs/heads/}"
  if [[ "$remote_ref" == refs/heads/* ]] && is_protected "$branch"; then
    echo "" >&2
    echo "============================================================" >&2
    echo "  Direct push to '$branch' is blocked." >&2
    echo "  Open a pull request instead (this includes you)." >&2
    echo "" >&2
    echo "  Suggested flow:" >&2
    echo "    git switch -c your-topic-branch" >&2
    echo "    git push -u origin HEAD" >&2
    echo "    gh pr create --fill" >&2
    echo "" >&2
    echo "  Emergency only: ALLOW_DIRECT_PUSH=1 git push" >&2
    echo "============================================================" >&2
    echo "" >&2
    blocked=1
  fi
done

if [[ "$blocked" -eq 1 ]]; then
  exit 1
fi

exit 0
