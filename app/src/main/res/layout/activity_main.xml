<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_screen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="32dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/home_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="@string/home_prompt"
        android:textColor="@color/text_primary"
        android:textSize="30sp" />

    <GridLayout
        android:id="@+id/action_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:alignmentMode="alignMargins"
        android:columnCount="2"
        android:rowCount="2"
        android:useDefaultMargins="false">

        <Button
            android:id="@+id/action_call"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_row="0"
            android:layout_rowWeight="1"
            android:layout_column="0"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="8dp"
            android:background="@drawable/action_call_button"
            android:drawableTop="@drawable/ic_call"
            android:drawablePadding="18dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:minHeight="160dp"
            android:padding="20dp"
            android:stateListAnimator="@null"
            android:text="@string/action_call"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="24sp" />

        <Button
            android:id="@+id/action_youtube"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_row="0"
            android:layout_rowWeight="1"
            android:layout_column="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="8dp"
            android:background="@drawable/action_youtube_button"
            android:drawableTop="@drawable/ic_youtube"
            android:drawablePadding="18dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:minHeight="160dp"
            android:padding="20dp"
            android:stateListAnimator="@null"
            android:text="@string/action_youtube"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="24sp" />

        <Button
            android:id="@+id/action_speak"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_row="1"
            android:layout_rowWeight="1"
            android:layout_column="0"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="8dp"
            android:background="@drawable/action_speak_button"
            android:drawableTop="@drawable/ic_speak"
            android:drawablePadding="18dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:minHeight="160dp"
            android:padding="20dp"
            android:stateListAnimator="@null"
            android:text="@string/action_speak"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="24sp" />

        <Button
            android:id="@+id/action_map"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_row="1"
            android:layout_rowWeight="1"
            android:layout_column="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            android:layout_margin="8dp"
            android:background="@drawable/action_map_button"
            android:drawableTop="@drawable/ic_map"
            android:drawablePadding="18dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:minHeight="160dp"
            android:padding="20dp"
            android:stateListAnimator="@null"
            android:text="@string/action_map"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="24sp" />

    </GridLayout>

</LinearLayout>
