<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <WebView
        android:id="@+id/yt_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Touch shield: swallows every touch on the video, ads included. -->
    <View
        android:id="@+id/yt_touch_shield"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/yt_ad_notice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="24dp"
        android:background="#CC000000"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"
        android:text="@string/yt_ad_notice"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/yt_unavailable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/yt_unavailable"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:visibility="gone" />

</FrameLayout>
