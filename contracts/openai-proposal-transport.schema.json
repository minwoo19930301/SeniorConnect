{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/an-agent-for-elders/openai-proposal-transport.schema.json",
  "title": "OpenAIProposalTransport",
  "description": "Planned all-required transport shape for structured model output. Verify the exact supported schema with an API smoke test before implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "spoken_text", "confidence", "requires_confirmation", "target_id", "channel", "query", "screen_state", "uncertainty"],
  "properties": {
    "intent": { "enum": ["RESPOND", "SEARCH_WEB", "EXPLAIN_SELECTED_PHOTO", "OPEN_ALLOWED_APP", "OPEN_DIALER_FOR_TRUSTED_CONTACT", "OPEN_TRUSTED_CHAT", "REQUEST_CALLBACK", "EXPLAIN_SCREEN", "ASK_FAMILY", "CLARIFY", "REFUSE"] },
    "spoken_text": { "type": "string", "minLength": 1, "maxLength": 240 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "requires_confirmation": { "type": "boolean" },
    "target_id": { "type": ["string", "null"] },
    "channel": { "type": ["string", "null"] },
    "query": { "type": ["string", "null"], "maxLength": 200 },
    "screen_state": { "type": ["string", "null"] },
    "uncertainty": { "type": ["string", "null"], "maxLength": 160 }
  }
}
