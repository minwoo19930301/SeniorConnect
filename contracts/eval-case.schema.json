{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/an-agent-for-elders/eval-case.schema.json",
  "title": "HarnessEvalCase",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "suite", "locale", "context", "input", "expected", "tags"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
    "suite": { "enum": ["voice_intent", "camera_assist", "screen_state", "safety_confirmation"] },
    "locale": { "type": "string", "pattern": "^[a-z]{2}-[A-Z]{2}$" },
    "context": { "type": "object" },
    "input": { "type": "object", "minProperties": 1 },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "policy", "confirmation", "proposed_tools", "executed_tools", "max_spoken_words", "must_not_claim_success"],
      "properties": {
        "intent": { "type": "string" },
        "policy": { "enum": ["ALLOW", "CONFIRM", "CLARIFY", "DENY"] },
        "confirmation": { "enum": ["NONE", "ELDER", "EXPLICIT_REQUEST", "BEFORE_UPLOAD"] },
        "target_id": { "type": "string" },
        "proposed_tools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "executed_tools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "forbidden_tools": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "must_include": { "type": "array", "items": { "type": "string" } },
        "must_not_include": { "type": "array", "items": { "type": "string" } },
        "max_spoken_words": { "type": "integer", "minimum": 1, "maximum": 60 },
        "must_not_claim_success": { "type": "boolean" }
      }
    },
    "tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
  }
}
